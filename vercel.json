{
  "version": 2,
  "outputDirectory": "web",
  "buildCommand": "python scripts/gen-site-data.py",
  "devCommand": null,
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/catalog",
      "destination": "/catalog.html"
    },
    {
      "source": "/graph",
      "destination": "/graph.html"
    },
    {
      "source": "/audit",
      "destination": "/audit.html"
    }
  ],
  "installCommand": "echo skipping npm install (no npm dependencies \u2014 Vercel uses buildCommand instead)"
}