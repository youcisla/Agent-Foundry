seq: {
  shape: sequence_diagram
  U: User prompt
  L: run_loop
  P: planner.rank_skills
  E: executor
  M: "LiteLLM (any model)"
  J: "judge (af-critic)"
  DB: "SQLite executions.db"
  U -> L: "/af \"kill generic AI slop\""
  L -> P: rank_skills(prompt, index)
  P -> L: "top match (anti-slop, 0.24)"
  L -> L: budget guard
  L -> E: build_messages(prompt, body)
  E -> M: POST /v1/messages
  M -> E: response text
  E -> L: response + cost
  judge (optional): {
    L -> J: score output
    J -> L: "{corr, slop, scope, verdict}"
  }
  L -> DB: log_execution(...)
  L -> U: "LoopResponse {output, plan, judge?}"
}
