direction: right
classes: {
  tight: { style: { fill: "#22222a"; stroke: "#4ade80"; font-color: "#e8e8ea"; border-radius: 8 } }
  med:   { style: { fill: "#22222a"; stroke: "#f5a623"; font-color: "#e8e8ea"; border-radius: 8 } }
  low:   { style: { fill: "#22222a"; stroke: "#8b8b95"; font-color: "#e8e8ea"; border-radius: 8 } }
}
Tight: "Tight  ·  cohesion > 0.5" {
  style: { fill: "#131316"; stroke: "#4ade80"; stroke-dash: 5; font-color: "#4ade80" }
  F: foundry-eval { class: tight }
  P: provenance-audit { class: tight }
}
Medium: "Medium  ·  0.1 – 0.5" {
  style: { fill: "#131316"; stroke: "#f5a623"; stroke-dash: 5; font-color: "#f5a623" }
  LOG: logging_db { class: med }
  IDX: indexer { class: med }
  EX: executor { class: med }
  PL: planner { class: med }
}
Low: "Low  ·  < 0.1  (cross-cutting)" {
  style: { fill: "#131316"; stroke: "#8b8b95"; stroke-dash: 5; font-color: "#8b8b95" }
  CFG: Config { class: low }
  CLI: cli { class: low }
  SCH: "JSON schema fields" { class: low }
}
