direction: right
classes: {
  box:    { style: { fill: "#22222a"; stroke: "#2a2a33"; font-color: "#e8e8ea"; border-radius: 8 } }
  accent: { style: { fill: "#22222a"; stroke: "#f5a623"; font-color: "#e8e8ea"; border-radius: 8 } }
  green:  { style: { fill: "#22222a"; stroke: "#4ade80"; font-color: "#e8e8ea"; border-radius: 8 } }
  blue:   { style: { fill: "#22222a"; stroke: "#6496ff"; font-color: "#e8e8ea"; border-radius: 8 } }
}
AF: "Agent Foundry /" {
  style: { fill: "#131316"; stroke: "#2a2a33"; stroke-dash: 5; font-color: "#e8e8ea" }
  cfg: "config.py\nfrozen Config" { class: accent }
  cli: "cli.py\n10 commands" { class: box }
  daemon: "daemon.py\nFastAPI" { class: green }
  planner: planner.py { class: box }
  executor: "executor.py\nLiteLLM" { class: box }
  loop: loop.py { class: box }
  judge: "judge.py\naf-critic" { class: box }
  indexer: indexer.py { class: box }
  logdb: logging_db.py { class: box }
  models: models.py { class: box }
}
Out: "Repo root" {
  style: { fill: "#131316"; stroke: "#2a2a33"; stroke-dash: 5; font-color: "#e8e8ea" }
  sk: "skills/\n30 SKILL.md" { class: box }
  ag: "agents/\n3 AGENT.md" { class: box }
  web: "web/\nthis site" { class: box }
  sc: "scripts/\ngraphify, eval, nox" { class: box }
  doc: "docs/\nplans, architecture" { class: box }
  gfy: "graphify-out/\ngenerated" { class: blue }
}
AF.cfg -> AF.daemon
AF.cfg -> AF.loop
AF.indexer -> AF.planner
AF.planner -> AF.loop
AF.loop -> AF.executor
AF.executor -> AF.loop
AF.loop -> AF.judge
AF.loop -> AF.logdb
AF.daemon -> AF.loop
Out.sk -> AF.indexer
Out.sk -> Out.gfy
Out.sc -> Out.gfy
Out.gfy -> Out.web
