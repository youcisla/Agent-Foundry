direction: down
classes: {
  inp:   { style: { fill: "#f5a623"; stroke: "#f5a623"; font-color: "#0a0a0b"; bold: true; border-radius: 10 } }
  proc:  { style: { fill: "#22222a"; stroke: "#6496ff"; font-color: "#e8e8ea"; border-radius: 8 } }
  match: { style: { fill: "#22222a"; stroke: "#f5a623"; font-color: "#e8e8ea" } }
  llm:   { style: { fill: "#22222a"; stroke: "#4ade80"; font-color: "#e8e8ea" } }
  store: { style: { fill: "#22222a"; stroke: "#8b8b95"; font-color: "#c9c9d0" } }
  out:   { style: { fill: "#f5a623"; stroke: "#f5a623"; font-color: "#0a0a0b"; bold: true; border-radius: 10 } }
}
Input: Input {
  style: { fill: "#131316"; stroke: "#2a2a33"; stroke-dash: 5; font-color: "#8b8b95" }
  A: Your prompt { class: inp; shape: oval }
}
Orchestrator: "Agent Foundry — Orchestrator" {
  style: { fill: "#131316"; stroke: "#f5a623"; stroke-dash: 5; font-color: "#e8e8ea" }
  B: Skill matcher { class: match; shape: diamond }
  C: "Planner: rank & cost" { class: proc }
  D: "Executor: LiteLLM" { class: proc }
}
LLM: "LLM layer" {
  style: { fill: "#131316"; stroke: "#4ade80"; stroke-dash: 5; font-color: "#e8e8ea" }
  E: Provider { class: llm; shape: circle }
}
Storage: Storage {
  style: { fill: "#131316"; stroke: "#8b8b95"; stroke-dash: 5; font-color: "#e8e8ea" }
  F: "SQLite log" { class: store; shape: cylinder }
}
G: Response { class: out }
Input.A -> Orchestrator.B
Orchestrator.B -> Orchestrator.C
Orchestrator.C -> Orchestrator.D
Orchestrator.D -> LLM.E
LLM.E -> Orchestrator.D
Orchestrator.D -> Storage.F
Storage.F -> G
